# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Signed cookie secret (min 32 chars)
ATTRIBUTION_SECRET=change-this-to-a-random-32-char-secret

# Cron job auth (set in Vercel)
CRON_SECRET=your-cron-secret

# Set to true for demo: escrow eligible after 60 seconds instead of 48h
DEMO_FAST_ESCROW=true
